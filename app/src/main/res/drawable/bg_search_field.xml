<?xml version="1.0" encoding="utf-8"?>
<!--
  Subtle pill-shaped background for the search EditText. Translucent white fill so the page
  gradient still shows through, with a faint border so the input is recognizable without the
  solid panel that used to wrap the whole search row.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="22dp" />
    <solid android:color="#1AFFFFFF" />
    <stroke android:width="1dp" android:color="#33FFFFFF" />
</shape>
