<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="8dp"
    android:background="@color/forecast_item_overlay">

    <!-- Day name (e.g. "Today" / "Friday") + secondary date -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvDailyDayName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary_on_brand"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Hôm nay" />

        <TextView
            android:id="@+id/tvDailyDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary_on_brand"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            tools:text="09/05" />
    </LinearLayout>

    <!-- Pop% (precipitation probability) — hidden when below threshold -->
    <TextView
        android:id="@+id/tvDailyPop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary_on_brand"
        android:textSize="12sp"
        android:layout_marginEnd="8dp"
        android:visibility="gone"
        tools:visibility="visible"
        tools:text="💧 60%" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lavDailyIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />

    <!-- min / max temp range, right-aligned -->
    <TextView
        android:id="@+id/tvDailyTempRange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary_on_brand"
        android:textSize="14sp"
        android:textStyle="bold"
        tools:text="22° / 30°" />
</LinearLayout>
