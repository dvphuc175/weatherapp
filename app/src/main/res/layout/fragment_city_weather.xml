<?xml version="1.0" encoding="utf-8"?>
<!--
  One page of the multi-city pager. Self-contained: own SwipeRefreshLayout, own gradient,
  own loading/error/content states, own offline banner. Nothing shared with siblings except
  the temperature unit (read from UserPreferences).
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_subtle">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layoutFragmentRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Offline banner — shown when this page is served from cache. -->
            <TextView
                android:id="@+id/tvOfflineBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:padding="10dp"
                android:gravity="center"
                android:background="@color/offline_banner_background"
                android:textColor="@color/offline_banner_text"
                android:textSize="13sp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="Đang offline · Cập nhật 3 phút trước" />

            <!-- Loading state: shown only on first load (data null + isLoading). -->
            <FrameLayout
                android:id="@+id/layoutLoading"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:visibility="gone"
                tools:visibility="gone">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/text_primary_on_brand" />
            </FrameLayout>

            <!-- Error state: shown when there is no data and the last load failed. -->
            <LinearLayout
                android:id="@+id/layoutError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp"
                android:visibility="gone"
                tools:visibility="gone">

                <TextView
                    android:id="@+id/tvErrorMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/error_default_message"
                    android:textColor="@color/text_primary_on_brand"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetry"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/retry_button"
                    app:icon="@android:drawable/ic_popup_sync" />
            </LinearLayout>

            <!-- Content state: header + forecast + chart + metrics cards. -->
            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="10dp">

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lavLocationIcon"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:layout_marginEnd="8dp"
                            android:contentDescription="@string/saved_city_content_description"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true" />

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary_on_brand"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:text="@string/loading_uppercase" />
                    </LinearLayout>

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lavWeatherIcon"
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:layout_marginTop="5dp"
                        android:contentDescription="@string/updating"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                    <TextView
                        android:id="@+id/tvTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/placeholder_temperature"
                        android:textColor="@color/text_primary_on_brand"
                        android:textSize="60sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/updating"
                        android:textColor="@color/text_secondary_on_brand"
                        android:textSize="18sp"
                        android:layout_marginTop="5dp" />

                    <!-- Sunrise / sunset pill, sits below the description. -->
                    <LinearLayout
                        android:id="@+id/layoutSunCycle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/tvSunrise"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sunrise_placeholder"
                            android:textColor="@color/text_primary_on_brand"
                            android:textSize="14sp"
                            tools:text="🌅 5:42" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="14dp"
                            android:layout_marginHorizontal="12dp"
                            android:background="@color/text_secondary_on_brand" />

                        <TextView
                            android:id="@+id/tvSunset"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sunset_placeholder"
                            android:textColor="@color/text_primary_on_brand"
                            android:textSize="14sp"
                            tools:text="🌇 18:30" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleForecastMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForecastHourly"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/forecast_mode_hourly" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForecastDaily"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/forecast_mode_daily" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvForecast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingStart="20dp"
                    android:clipToPadding="false" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/lineChartTemp"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="20dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDailyForecast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="20dp"
                    android:visibility="gone"
                    tools:visibility="gone" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardHumidityFeels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/card_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/humidity_label"
                                android:textColor="@color/card_text_secondary"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvHumidity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_percent"
                                android:textColor="@color/card_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="5dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/feels_like_label"
                                android:textColor="@color/card_text_secondary"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvFeelsLike"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_temperature"
                                android:textColor="@color/card_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginTop="5dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Details card: wind / pressure / visibility. -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWindPressureVisibility"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="@color/card_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/wind_label"
                                android:textColor="@color/card_text_secondary"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvWind"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                android:textColor="@color/card_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="5dp"
                                tools:text="3.4 m/s" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pressure_label"
                                android:textColor="@color/card_text_secondary"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvPressure"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                android:textColor="@color/card_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="5dp"
                                tools:text="1013 hPa" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/visibility_label"
                                android:textColor="@color/card_text_secondary"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvVisibility"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_dash"
                                android:textColor="@color/card_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="5dp"
                                tools:text="10 km" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
